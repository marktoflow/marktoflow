{
  "name": "marktoflow",
  "version": "2.0.5",
  "description": "Agent automation framework with native MCP support and direct SDK integration",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "turbo run build",
    "test": "turbo run test",
    "test:integration": "turbo run test:integration",
    "test:all": "turbo run test:all",
    "test:smoke": "vitest run --config tests/smoke/vitest.smoke.config.ts",
    "lint": "turbo run lint",
    "format": "prettier --write \"packages/*/src/**/*.ts\"",
    "clean": "turbo run clean && rm -rf node_modules",
    "publish:prepare": "node scripts/prepare-publish.js prepare",
    "publish:restore": "node scripts/prepare-publish.js restore",
    "publish:test": "node scripts/test-packages.js",
    "publish:dry-run": "node scripts/publish.js --dry-run",
    "publish": "node scripts/publish.js"
  },
  "keywords": [
    "automation",
    "workflow",
    "mcp",
    "ai",
    "slack",
    "jira",
    "github"
  ],
  "author": "Scott Glover",
  "license": "AGPL-3.0-only",
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@vitest/coverage-v8": "^2.1.0",
    "prettier": "^3.4.0",
    "turbo": "^2.3.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.15.0",
  "dependencies": {
    "@openai/codex-sdk": "^0.91.0"
  },
  "pnpm": {
    "overrides": {
      "qs@<6.14.2": ">=6.14.2",
      "xml2js@<0.6.2": ">=0.6.2",
      "@isaacs/brace-expansion@<=5.0.0": ">=5.0.1",
      "fast-xml-parser@<5.5.7": ">=5.5.7",
      "ajv@<8.18.0": ">=8.18.0",
      "esbuild@<0.24.2": ">=0.24.2",
      "axios": "1.13.5",
      "langsmith": ">=0.5.0",
      "basic-ftp@<5.2.0": ">=5.2.0",
      "undici@>=7.0.0 <7.24.0": ">=7.24.0",
      "socket.io-parser@>=4.0.0 <4.2.6": ">=4.2.6",
      "express-rate-limit@>=8.2.0 <8.2.2": ">=8.2.2",
      "@hono/node-server@<1.19.10": ">=1.19.10",
      "hono@<4.12.7": ">=4.12.7",
      "underscore@<=1.13.7": ">=1.13.8",
      "rollup@>=4.0.0 <4.59.0": ">=4.59.0",
      "dompurify@<3.3.2": ">=3.3.2"
    }
  }
}
